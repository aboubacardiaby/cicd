
@{
    ViewData["Title"] = "MVC Learning";
}

<!-- HERO -->

<section class="hero">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>

    <p> Learn CICD PIPELINE WITH ABOU EVERY WEDNESDAY .</p>

    <div class="hero-bg"></div>
    <div class="hero-wash"></div>
    <div class="hero-content">
        <p class="hero-kicker">Software Architecture</p>
        <h1 class="hero-title">
            Model<br><em>View</em><br>Controller
        </h1>
        <p class="hero-deck">
            MVC separates your application into three powerful layers.
        </p>

        ```
        <div class="hero-trio">
            <span class="trio-pill m">Model</span>
            <span class="trio-pill v">View</span>
            <span class="trio-pill c">Controller</span>
        </div>
    </div>
    ```

</section>

<div class="container">

    ```
    <!-- INTRO -->
    <section class="intro reveal">
        <div class="intro-left">
            <h2>Separation of <em>concerns</em></h2>
            <p>
                MVC divides your application into Model, View, and Controller.
            </p>
        </div>

        <div class="intro-right">
            <div class="quote">
                "Model manages data, View displays it, Controller connects both."
            </div>
        </div>
    </section>

    <!-- THREE LAYERS -->
    <section class="three-col reveal">

        <div class="col-card model">
            <h3>Model</h3>
            <p>Handles data, database, and business logic.</p>
        </div>

        <div class="col-card view">
            <h3>View</h3>
            <p>Displays UI and user interface.</p>
        </div>

        <div class="col-card ctrl">
            <h3>Controller</h3>
            <p>Handles requests and connects Model & View.</p>
        </div>

    </section>

    <!-- FLOW -->
    <section class="flow-section reveal">
        <h3>Request Flow</h3>
        <div class="flow-steps">
            <div>User Request</div>
            <div>Controller</div>
            <div>Model</div>
            <div>View</div>
            <div>Response</div>
        </div>
    </section>
    ```

</div>
